<Page x:Class="LABA15.Pages.Task5Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 
      xmlns:local="clr-namespace:LABA15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Task5Page">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E3F2FD" Offset="0"/>
                <GradientStop Color="#BBDEFB" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel Margin="20">

            <ComboBox x:Name="StyleSelector" SelectedIndex="0" Margin="0,0,0,10">
                <ComboBoxItem Content="Стандартный" Tag="Standard"/>
                <ComboBoxItem Content="Крупный синий" Tag="BigBlue"/>
                <ComboBoxItem Content="Курсив серый" Tag="ItalicGray"/>
            </ComboBox>

            <TextBox x:Name="TB1" AcceptsReturn="True" Height="100" Margin="0,5" VerticalScrollBarVisibility="Auto">
                <TextBox.Style
>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem.Tag, ElementName=StyleSelector}" Value="BigBlue">
                                <Setter Property="FontSize" Value="20"/>
                                <Setter Property="Foreground" Value="Blue"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedItem.Tag, ElementName=StyleSelector}" Value="ItalicGray">
                                <Setter Property="FontStyle" Value="Italic"/>
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBox x:Name="TB2" AcceptsReturn="True" Height="100" Margin="0,5" VerticalScrollBarVisibility="Auto" Style="{Binding Style, ElementName=TB1}"/>

            <UniformGrid Columns="3" Margin="0,10">
                <Button Content="Открыть" Margin="5"/>
                <Button Content="Очистить" Click="Clear_Click" Margin="5"/>
                <Button x:Name="BtnClose" Content="Закрыть" Margin="5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text.Length, ElementName=TB1}" Value="0"/>
                                        <Condition Binding="{Binding Text.Length, ElementName=TB2}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="True"/>
                                </MultiDataTrigger>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Orange"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Page>