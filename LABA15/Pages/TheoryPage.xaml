<Page x:Class="LABA15.Pages.TheoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LABA15.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
        Title="TheoryPage">
    <Page.Resources>
        <Style TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=slider1, Path=Value}" Value="0">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <Grid Background="White">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="20">
            <Button Content="Открыть" Margin="5" Padding="10,5"/>
            <Button Content="Обработать" Margin="5" Padding="10,5"/>
            <Slider x:Name="slider1" Width="150" Minimum="0" Maximum="10" Margin="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
        </StackPanel>
        <TextBlock Text="Передвиньте ползунок в 0, чтобы кнопки стали неактивными" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
    </Grid>
</Page> 